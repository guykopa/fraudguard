{
  "title": "fraudguard",
  "uid": "fraudguard-v1",
  "schemaVersion": 36,
  "version": 1,
  "panels": [
    {
      "id": 1,
      "title": "Predictions per second",
      "type": "timeseries",
      "targets": [
        {
          "expr": "rate(fraudguard_predictions_total[1m])",
          "legendFormat": "{{label}}"
        }
      ]
    },
    {
      "id": 2,
      "title": "Inference latency p99 (s)",
      "type": "timeseries",
      "targets": [
        {
          "expr": "histogram_quantile(0.99, rate(fraudguard_inference_latency_seconds_bucket[5m]))",
          "legendFormat": "p99"
        }
      ]
    },
    {
      "id": 3,
      "title": "PSI drift score per feature",
      "type": "bargauge",
      "targets": [
        {
          "expr": "fraudguard_drift_psi_score",
          "legendFormat": "{{feature}}"
        }
      ]
    },
    {
      "id": 4,
      "title": "HTTP requests per second",
      "type": "timeseries",
      "targets": [
        {
          "expr": "rate(http_requests_total[1m])",
          "legendFormat": "{{method}} {{handler}}"
        }
      ]
    }
  ]
}
